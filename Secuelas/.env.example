# Copy this file to .env and fill in the values before deploying.
# In Railway, set these as environment variables in the project dashboard.

# REQUIRED: A long random secret string for signing session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_me_to_a_long_random_string

# OPTIONAL: Override the SQLite DB path (default: backend/instance/secuelas_game.db)
# DATABASE_URL=sqlite:////data/secuelas_game.db

# OPTIONAL: Extra CORS origins for local development (comma-separated).
# Not needed in production since Flask serves the frontend from the same origin.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
